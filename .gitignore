# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─────────────────────────────────────────────
# 1. Secrets & Environment Variables (CRITICAL)
# ─────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─────────────────────────────────────────────
# 2. Dependencies
# ─────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─────────────────────────────────────────────
# 3. Build Outputs & Framework Cache
# ─────────────────────────────────────────────
/.next/
/out/
/build
/dist/

# ─────────────────────────────────────────────
# 4. Testing & Coverage
# ─────────────────────────────────────────────
/coverage

# ─────────────────────────────────────────────
# 5. Vercel
# ─────────────────────────────────────────────
.vercel

# ─────────────────────────────────────────────
# 6. TypeScript
# ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────
# 7. Debug Logs
# ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─────────────────────────────────────────────
# 8. Operating System
# ─────────────────────────────────────────────
.DS_Store
*.pem

# ─────────────────────────────────────────────
# 9. Editor & IDE
# ─────────────────────────────────────────────
.idea/

# ─────────────────────────────────────────────
# 10. Python (RAG Pipeline)
# ─────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─────────────────────────────────────────────
# 11. Local RAG Artifacts
# ─────────────────────────────────────────────
rag-pipeline/*.epub/

# ─────────────────────────────────────────────
# 12. Misc
# ─────────────────────────────────────────────
ctx2skill-loop.ts
